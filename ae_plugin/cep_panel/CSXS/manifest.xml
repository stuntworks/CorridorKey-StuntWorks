<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.corridorkey.panel" ExtensionBundleVersion="1.0.0">
    <ExtensionList>
        <Extension Id="com.corridorkey.panel.main" Version="1.0.0"/>
    </ExtensionList>
    <ExecutionEnvironment>
        <HostList>
            <Host Name="AEFT" Version="[22.0,99.9]"/>
            <Host Name="PPRO" Version="[22.0,99.9]"/>
        </HostList>
        <LocaleList>
            <Locale Code="All"/>
        </LocaleList>
        <RequiredRuntimeList>
            <RequiredRuntime Name="CSXS" Version="10.0"/>
        </RequiredRuntimeList>
    </ExecutionEnvironment>
    <DispatchInfoList>
        <Extension Id="com.corridorkey.panel.main">
            <DispatchInfo>
                <Resources>
                    <MainPath>./index.html</MainPath>
                    <ScriptPath>./jsx/host.jsx</ScriptPath>
                    <!-- The enable-nodejs flag turns on Node.js inside the panel so
                         panel JS can call child_process.spawnSync with an argv array
                         (no shell, so no injection) to run Python. The mixed-context
                         flag lets HTML and Node share globals so require works directly.
                         Removing either flag forces Python invocation back through
                         ExtendScript system.callSystem, which was the injection path
                         we eliminated. Do not remove. -->
                    <CEFCommandLine>
                        <Parameter>--enable-nodejs</Parameter>
                        <Parameter>--mixed-context</Parameter>
                    </CEFCommandLine>
                </Resources>
                <Lifecycle>
                    <AutoVisible>true</AutoVisible>
                </Lifecycle>
                <UI>
                    <Type>Panel</Type>
                    <Menu>CorridorKey</Menu>
                    <Geometry>
                        <Size>
                            <Width>350</Width>
                            <Height>500</Height>
                        </Size>
                    </Geometry>
                    <Icons>
                        <Icon Type="Normal">./icons/icon.png</Icon>
                    </Icons>
                </UI>
            </DispatchInfo>
        </Extension>
    </DispatchInfoList>
</ExtensionManifest>
